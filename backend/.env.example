SPRING_PROFILES_ACTIVE=local
DB_URL=jdbc:mysql://localhost:3306/ddoya?useSSL=false&serverTimezone=Asia/Seoul&characterEncoding=UTF-8&allowPublicKeyRetrieval=true
DB_USERNAME=YOUR_DB_USERNAME
DB_PASSWORD=YOUR_DB_PASSWORD
JWT_SECRET=YOUR_SUPER_SECRET_KEY_MUST_BE_MINIMUM_32_CHARACTERS_LONG
S3_ENABLED=false

# S3 준비 완료 시 주석 해제 및 변수 값 설정
# --- [AWS S3 인증 정보 (S3_ENABLED=true 일 때 필수)] ---
# AWS_ACCESS_KEY_ID=발급받은_엑세스_키
# AWS_SECRET_ACCESS_KEY=발급받은_시크릿_키
# AWS_REGION=ap-northeast-2
# S3_BUCKET=생성한_버킷_이름
